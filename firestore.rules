rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper function for admin check
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email != null &&
             request.auth.token.email.endsWith('@baexpress.co.uk');
    }

    // Drivers collection - admins can read
    match /drivers/{driverId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // First access codes - admins can create and read
    match /firstAccessCodes/{emailKey} {
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow read: if request.auth != null;
    }

    // Workspaces - admins only
    match /workspaces/{workspace} {
      allow read, write: if isAdmin();
      match /vendors/{vendorId} {
        allow read, write: if isAdmin();
      }
    }
  }
}
